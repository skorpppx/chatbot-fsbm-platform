# Configuration du chatbot-service
SERVICE_NAME=chatbot-service
SERVICE_PORT=5001
ENV=development
DEBUG=true

# MySQL (lecture seule conseillée)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=fsbm_db
DB_USER=root
DB_PASSWORD=

# Communication inter-services
ACADEMIC_SERVICE_URL=http://localhost:5002

# NLP
CONFIDENCE_THRESHOLD=0.15
MAX_HISTORY_MESSAGES=20
MAX_MESSAGE_LENGTH=500

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ───────────────────────────────────────────────────────────────────────────────
# LLM CONFIGURATION (optionnel - sinon fallback TF-IDF automatique)
# ───────────────────────────────────────────────────────────────────────────────

# Groq API (RECOMMANDE) : heberge LLaMA 3.3 70B gratuitement
#   1. Inscription : https://console.groq.com (gratuit, 30 sec)
#   2. Cle API : https://console.groq.com/keys
#   3. Coller ici la cle qui commence par gsk_
GROQ_API_KEY=
GROQ_MODEL=default
# default = llama-3.3-70b-versatile (qualite max)
# llama-fast = llama-3.1-8b-instant (latence min)
# mixtral = mixtral-8x7b-32768 (contexte long)

# HuggingFace API (FALLBACK si Groq indispo)
#   1. https://huggingface.co/settings/tokens
#   2. Cle commence par hf_
HF_API_KEY=

# RAG : nombre de passages a recuperer dans le contexte (defaut 3)
RAG_TOP_K=3
